JWT_SECRET=change-this-to-a-long-random-secret
BACKUP_SECRET=change-this-to-a-long-random-backup-secret
MYSQL_URL=mysql://user:password@host:3306/database

# Alternative DB variables if MYSQL_URL is not used:
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=

# Google Drive OAuth 2.0 (required for Drive file operations and backup):
# Create credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REDIRECT_URI=https://your-app-domain.com/api/drive/callback
#
# After completing the OAuth flow the refresh token is stored in the database
# automatically. You can also set it directly as an env variable:
# GOOGLE_REFRESH_TOKEN=
#
# ID of the Google Drive folder where files/backups will be stored:
# GOOGLE_DRIVE_FOLDER_ID=
#
# Alternative: service account JSON (base64 or raw JSON string):
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional SMS:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
# FAST2SMS_API_KEY=
# FAST2SMS_ROUTE=q
